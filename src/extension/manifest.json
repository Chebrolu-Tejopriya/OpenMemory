{
  "manifest_version": 3,
  "name": "OpenMemory",
  "version": "1.0.0",
  "description": "Semantic search for your design inspirations",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open OpenMemory"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
